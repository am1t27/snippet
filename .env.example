# Backend (game server) environment. Copy to .env for local, and set these on
# your persistent host (Railway / Render / Fly) for production.
#
# NOTE: this server is a long-running, stateful WebSocket process. It CANNOT run
# on Vercel serverless. Only the client/ SPA deploys to Vercel. See DEPLOY.md.

# Port the server listens on (host usually injects this).
PORT=3000

# Set to "production" in prod. When set, an unset CLIENT_ORIGIN fails CLOSED
# (cross-origin blocked) instead of allowing all origins.
NODE_ENV=production

# Comma-separated allowlist of web origins allowed to connect (Socket.IO + HTTP).
# REQUIRED in production — e.g. your Vercel URL. No trailing slash.
CLIENT_ORIGIN=https://your-app.vercel.app

# Google OAuth web client ID (same value as the client's VITE_GOOGLE_CLIENT_ID).
# Leave blank to disable sign-in (guest-only).
GOOGLE_CLIENT_ID=

# Abuse caps (optional; sensible defaults applied if unset).
MAX_ROOMS=500
MAX_CONN_PER_IP=30

# Optional, all dormant unless set:
# DATABASE_URL=postgres://...        # global leaderboard (also: npm install pg)
# REDIS_URL=redis://...              # multi-instance socket fan-out
# SENTRY_DSN=https://...             # error monitoring
# LOG_FORMAT=json                    # one-line JSON logs for aggregators
# ITUNES_BASE=https://itunes.apple.com/search  # override for tests
