# Client (Vite SPA) environment. Copy to .env.local for local overrides, and set
# these in the Vercel project dashboard for production builds.

# Backend URL the client connects to in production (your Railway/Render/Fly host).
# In dev, leave blank — Vite proxies /socket.io to localhost:3000.
VITE_SOCKET_URL=https://your-backend.up.railway.app

# Google OAuth web client ID (same value as the backend's GOOGLE_CLIENT_ID).
# Leave blank to disable sign-in (guest-only).
VITE_GOOGLE_CLIENT_ID=
