# Copy to .env.local for local overrides, and set these in the Vercel dashboard.

# Backend (Railway) URL the client connects to in production.
# In dev, leave blank — Vite proxies /socket.io to localhost:3000.
VITE_SOCKET_URL=https://your-backend.up.railway.app

# Google OAuth client ID (web). Added in Phase 2.
VITE_GOOGLE_CLIENT_ID=
